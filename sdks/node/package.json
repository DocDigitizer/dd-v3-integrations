{
  "name": "docdigitizer",
  "version": "0.2.0",
  "description": "Official Node.js/TypeScript SDK for the DocDigitizer document processing API",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0",
    "yaml": "^2.7.0"
  },
  "author": {
    "name": "DocDigitizer",
    "email": "support@docdigitizer.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DocDigitizer/dd-v3-integrations",
    "directory": "sdks/node"
  },
  "keywords": [
    "docdigitizer",
    "ocr",
    "pdf",
    "document-processing",
    "invoice",
    "extraction",
    "sdk"
  ]
}
